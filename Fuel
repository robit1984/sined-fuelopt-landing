    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter', sans-serif;
        }

        body {
            min-height: 100vh;
            background: #050508;
            color: #e0e0e0;
            overflow-x: hidden;
            position: relative;
        }

        /* Киберпанк-сетка */
        .cyber-grid {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-image: 
                linear-gradient(rgba(0, 229, 255, 0.03) 1px, transparent 1px),
                linear-gradient(90deg, rgba(0, 229, 255, 0.03) 1px, transparent 1px);
            background-size: 50px 50px;
            pointer-events: none;
            z-index: 1;
        }

        /* Сканирующая линия */
        .scan-line {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 3px;
            background: linear-gradient(90deg, transparent, #00e5ff, transparent);
            box-shadow: 0 0 20px #00e5ff;
            opacity: 0.3;
            animation: scan 6s linear infinite;
            pointer-events: none;
            z-index: 2;
        }

        @keyframes scan {
            0% { top: -10px; }
            100% { top: 100%; }
        }

        /* Слайдер */
        .hero-slider {
            position: relative;
            width: 100%;
            height: 400px;
            overflow: hidden;
            border-bottom: 1px solid rgba(0, 229, 255, 0.3);
            box-shadow: 0 0 40px rgba(0, 229, 255, 0.1);
        }

        .slider-container {
            display: flex;
            width: 300%;
            height: 100%;
            animation: slide 15s infinite;
        }

        .slide {
            width: 33.333%;
            height: 100%;
            background-size: cover;
            background-position: center;
            position: relative;
        }

        .slide::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(180deg, rgba(5,5,8,0.7) 0%, rgba(5,5,8,0.3) 50%, rgba(5,5,8,0.9) 100%);
        }

        .slide-1 { background-image: url('https://images.pexels.com/photos/221012/pexels-photo-221012.jpeg?auto=compress&cs=tinysrgb&w=1920'); }
        .slide-2 { background-image: url('https://images.pexels.com/photos/1117210/pexels-photo-1117210.jpeg?auto=compress&cs=tinysrgb&w=1920'); }
        .slide-3 { background-image: url('https://images.pexels.com/photos/2199293/pexels-photo-2199293.jpeg?auto=compress&cs=tinysrgb&w=1920'); }

        @keyframes slide {
            0%, 28% { transform: translateX(0); }
            33%, 61% { transform: translateX(-33.333%); }
            66%, 94% { transform: translateX(-66.666%); }
            100% { transform: translateX(0); }
        }

        /* 3D-контейнер */
        .canvas-container {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: 3;
        }

        #three-canvas {
            width: 100%;
            height: 100%;
            display: block;
        }

        /* Основной контент */
